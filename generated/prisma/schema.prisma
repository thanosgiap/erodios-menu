generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Dish {
  id        Int      @id @default(autoincrement())
  category  String
  nameEn    String
  nameEl    String
  nameRu    String
  descEn    String
  descEl    String
  descRu    String
  price     Float
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Manager {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}
